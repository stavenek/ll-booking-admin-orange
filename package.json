{
  "name": "ll-booking-admin-orange",
  "private": true,
  "version": "0.0.0",
  "description": "Lustiga Landet Booking Admin — static SPA. No build step; package.json exists only for lint tooling.",
  "scripts": {
    "lint:js": "eslint app.js checkin.js",
    "syntax:js": "node --check app.js && node --check checkin.js",
    "lint:yaml": "node -e \"require('js-yaml').load(require('fs').readFileSync('swagger.yaml','utf8')); console.log('swagger.yaml: ok')\"",
    "stamp": "node -e \"const fs=require('fs');const t=new Date().toISOString();fs.writeFileSync('build-info.js','window.LL_BUILD_TIME = '+JSON.stringify(t)+';\\n');console.log('build-info.js: '+t)\"",
    "check": "npm run syntax:js && npm run lint:js && npm run lint:yaml",
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true"
  },
  "devDependencies": {
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "js-yaml": "^4.1.0"
  }
}
